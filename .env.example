# ── Backend ───────────────────────────────────────────────────────────────────
# URL del backend FastAPI (in produzione: https://your-backend.onrender.com)
BACKEND_BASE=http://localhost:8000

# Chiave segreta condivisa tra frontend e backend (header X-Api-Key)
CASSANDRA_API_KEY=CHANGEME_SUPERSECRET_123

# ── Clerk (autenticazione) ────────────────────────────────────────────────────
# Ottenibili da https://dashboard.clerk.com → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Routing Clerk (non modificare)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/app
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/app

# ── PostHog (analytics) ───────────────────────────────────────────────────────
# Ottenibili da https://eu.posthog.com → Project Settings → API Keys
NEXT_PUBLIC_POSTHOG_KEY=phc_...
# Default: EU cloud. Cambia solo se usi un'istanza self-hosted.
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
